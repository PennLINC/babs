{% if input_datasets | selectattr('is_zipped') | list %}
# shellcheck disable=SC1091
find_single_zip_in_git_tree() {{ '{' }}
  local zip_search_path="$1"
  local name="$2"
  local hits count

  # Bounded listing: ``ls-files --with-tree=HEAD`` supports ``:(glob)`` (works with no-checkout clone); grep applies session filter.
  hits="$(
    git -C "${zip_search_path}" ls-files --with-tree=HEAD -- \
      "${subid}" \
      ":(glob)${subid}_*" \
      ":(glob)${subid}.*" \
      2>/dev/null | sed '/^$/d' | sort -u \
      | grep -E "{% raw %}${subid}{% endraw %}{% if processing_level == 'session' %}{% raw %}.*${sesid}{% endraw %}{% endif %}{% raw %}.*${name}.*\.zip${% endraw %}" \
      || true
  )"

  count="$(printf "%s\n" "${hits}" | sed '/^$/d' | wc -l | tr -d ' ')"

  if [ "${count}" -ne 1 ]; then
{% raw %}    echo "ERROR: Expected exactly 1 matching ${name} zip in ${zip_search_path}, found ${count}" 1>&2
    printf "%s\n" "${hits}" 1>&2
    exit 1
{% endraw %}
  fi

  # Repo-relative path only; caller joins with path_in_babs for absolute path from job clone.
  printf '%s\n' "${hits}"
{{ '}' }}

{% endif %}
